NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/salon-duong-chi
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
FRONTEND_URL=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Salon Duong Chi <no-reply@salon.local>

ZALO_WEBHOOK_URL=
ZALO_ACCESS_TOKEN=

PAYMENT_PROVIDER=cash
PAYMENT_MOCK_ENABLED=false
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

DEFAULT_ADMIN_NAME=Salon Admin
DEFAULT_ADMIN_EMAIL=admin@salonduongchi.vn
DEFAULT_ADMIN_PHONE=0900000000
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_STAFF_EMAIL=staff@salonduongchi.vn
DEFAULT_STAFF_PHONE=0900000001
DEFAULT_STAFF_PASSWORD=Staff@123456
DEFAULT_CUSTOMER_EMAIL=customer@salonduongchi.vn
DEFAULT_CUSTOMER_PHONE=0900000002
DEFAULT_CUSTOMER_PASSWORD=Customer@123456

# ─── Google OAuth (Đăng nhập bằng Google) ─────────────────────────────────────
# Lấy từ Google Cloud Console → APIs & Services → Credentials → Web application
GOOGLE_CLIENT_ID=your-project-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=https://salonduongchi.online/api/auth/google/callback

# Client ID dùng để build frontend bằng docker-compose (Vite nhúng vào lúc build)
# KHÔNG được khai báo GOOGLE_CLIENT_SECRET ở frontend hoặc trong build args của frontend.
VITE_GOOGLE_CLIENT_ID=your-project-id.apps.googleusercontent.com
