# Địa chỉ Base URL của Backend API (Production hoặc Local)
VITE_API_URL=https://api.salonduongchi.website

# Google Client ID dùng cho Google OAuth (chỉ cần VITE_ prefix, không cần GOOGLE_CLIENT_SECRET ở frontend)
# Lấy giá trị từ Google Cloud Console → APIs & Services → Credentials → Web application
# PHẢI khớp với GOOGLE_CLIENT_ID trong backend/.env
VITE_GOOGLE_CLIENT_ID=your-project-id.apps.googleusercontent.com

# Facebook App ID (nếu dùng đăng nhập Facebook)
VITE_FACEBOOK_APP_ID=your-facebook-app-id
