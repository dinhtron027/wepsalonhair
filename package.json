{
  "name": "salon-root",
  "private": true,
  "version": "1.0.0",
  "description": "Không gian làm việc cho ứng dụng salon toàn diện với frontend React và backend Node.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "dev:backend": "node --watch backend/server.js",
    "start": "node backend/server.js",
    "seed": "node backend/utils/seed.js"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.2",
    "nodemailer": "^8.0.11",
    "react-big-calendar": "^1.19.4",
    "react-hot-toast": "^2.6.0",
    "socket.io": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
